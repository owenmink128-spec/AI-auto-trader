# SAFETY MODE
# =========================================================
MODE = "PAPER_ONLY"   # LOCKED. Do not change.
KILL_SWITCH = False   # Set True to pause all new entries

# =========================================================
# SETTINGS
# =========================================================
SYMBOLS = ["AAPL", "NVDA", "AMD", "META", "TSLA", "SPY"]
MARKET_FILTER_SYMBOL = "SPY"

RISK_PER_TRADE = 0.01
BOX_PERIOD = 30
POLL_INTERVAL = 300          # 5 minutes
TIMEFRAME = "5m"
DATA_PERIOD = "1mo"

MAX_TRADES_PER_DAY = 3
MAX_DAILY_LOSS_PCT = 0.03
COOLDOWN_MINUTES = 30

TRAILING_STOP_ATR = 1.2
STOP_ATR_MULT = 1.5
TP_ATR_MULT = 3.0
BREAKOUT_BUFFER = 0.0015
BOUNCE_BUFFER_ATR = 0.30
MIN_VOLUME_MULT = 1.5

SKIP_FIRST_MINUTES = 15
MAX_OPEN_POSITIONS = 1

TRADE_LOG_FILE = "trade_journal.csv"
STATE_FILE = "paper_positions.csv"

